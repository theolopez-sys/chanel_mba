{
  "$schema": "https://tr.designtokens.org/format/",
  "description": "Internal European Design System — Design Tokens (W3C DTCG format)",
  "colors": {
    "black": {
      "$value": "#000000",
      "$type": "color",
      "$description": "var(--colors/black)"
    },
    "white": {
      "$value": "#FFFFFF",
      "$type": "color",
      "$description": "var(--colors/white)"
    },
    "accent": {
      "$value": "#B8964E",
      "$type": "color",
      "$description": "Gold accent — use sparingly"
    },
    "neutral": {
      "lowest": {
        "$value": "#f7f7f7",
        "$type": "color",
        "$description": "var(--colors/neutral/lowest) — confirmed from Figma DS"
      },
      "lower": {
        "$value": "#EDEDED",
        "$type": "color",
        "$description": "var(--colors/neutral/lower) — page background"
      },
      "low": {
        "$value": "#D4D4D4",
        "$type": "color",
        "$description": "var(--colors/neutral/low) — borders, separators"
      },
      "medium": {
        "$value": "#A0A0A0",
        "$type": "color",
        "$description": "var(--colors/neutral/medium)"
      },
      "high": {
        "$value": "#888888",
        "$type": "color",
        "$description": "var(--colors/neutral/high)"
      },
      "higher": {
        "$value": "#555555",
        "$type": "color",
        "$description": "var(--colors/neutral/higher)"
      },
      "highest": {
        "$value": "#333333",
        "$type": "color",
        "$description": "var(--colors/neutral/highest)"
      }
    },
    "surface": {
      "white": {
        "$value": "#FFFFFF",
        "$type": "color",
        "$description": "var(--colors/surface/white) — card background"
      }
    },
    "text": {
      "heading": {
        "$value": "#000000",
        "$type": "color",
        "$description": "var(--colors/text/heading)"
      },
      "body": {
        "$value": "#333333",
        "$type": "color",
        "$description": "var(--colors/text/body)"
      },
      "muted": {
        "$value": "#888888",
        "$type": "color"
      },
      "inverted": {
        "$value": "#FFFFFF",
        "$type": "color"
      }
    },
    "status": {
      "success": { "$value": "#2D6A4F", "$type": "color" },
      "warning": { "$value": "#E9C46A", "$type": "color" },
      "error":   { "$value": "#C1121F", "$type": "color" },
      "info":    { "$value": "#023E8A", "$type": "color" }
    }
  },
  "typography": {
    "fontFamily": {
      "title": {
        "$value": "ABChanel Corpo 2022",
        "$type": "fontFamily",
        "$description": "font/family/title — confirmed from Figma DS"
      },
      "text": {
        "$value": "Helvetica",
        "$type": "fontFamily",
        "$description": "font/family/text — body copy"
      }
    },
    "fontWeight": {
      "regular":  { "$value": 400, "$type": "fontWeight" },
      "bold":     { "$value": 600, "$type": "fontWeight", "$description": "font/weight/bold — confirmed from Figma DS" }
    },
    "fontSize": {
      "micro": { "$value": "10px", "$type": "dimension" },
      "xs":    { "$value": "11px", "$type": "dimension" },
      "sm":    { "$value": "14px", "$type": "dimension", "$description": "font/size/sm — confirmed from Figma DS" },
      "md":    { "$value": "16px", "$type": "dimension", "$description": "font/size/md — confirmed from Figma DS" },
      "lg":    { "$value": "20px", "$type": "dimension" },
      "xl":    { "$value": "22px", "$type": "dimension" },
      "2xl":   { "$value": "28px", "$type": "dimension" },
      "3xl":   { "$value": "40px", "$type": "dimension" },
      "hero":  { "$value": "64px", "$type": "dimension", "$description": "Hero / page title — desktop" }
    },
    "lineHeight": {
      "tight":  { "$value": 1.0, "$type": "number", "$description": "lineHeight: 100% — confirmed from Figma DS" },
      "normal": { "$value": 1.4, "$type": "number" },
      "loose":  { "$value": 1.6, "$type": "number" }
    },
    "letterSpacing": {
      "heading": { "$value": "0.1px",  "$type": "dimension", "$description": "heading letterSpacing — confirmed from Figma DS" },
      "label":   { "$value": "0.15em", "$type": "dimension", "$description": "Uppercase labels" },
      "tight":   { "$value": "0",      "$type": "dimension" }
    },
    "heading": {
      "h4": {
        "$value": { "family": "ABChanel Corpo 2022", "weight": 600, "size": "16px", "lineHeight": "100%", "letterSpacing": "0.1px" },
        "$type": "typography",
        "$description": "heading/h4 — confirmed from Figma DS"
      },
      "h5": {
        "$value": { "family": "ABChanel Corpo 2022", "weight": 600, "size": "14px", "lineHeight": "100%", "letterSpacing": "0.1px" },
        "$type": "typography",
        "$description": "heading/h5 — confirmed from Figma DS"
      }
    }
  },
  "spacing": {
    "xs":   { "$value": "8px",  "$type": "dimension", "$description": "size/gap/xs — confirmed from Figma DS" },
    "md":   { "$value": "16px", "$type": "dimension", "$description": "size/gap/md — confirmed from Figma DS" },
    "lg":   { "$value": "24px", "$type": "dimension", "$description": "size/gap/lg — confirmed from Figma DS" },
    "xl":   { "$value": "32px", "$type": "dimension", "$description": "size/gap/xl — confirmed from Figma DS" },
    "page": {
      "desktop": { "$value": "160px", "$type": "dimension", "$description": "Desktop horizontal padding" },
      "mobile":  { "$value": "20px",  "$type": "dimension", "$description": "Mobile horizontal padding" }
    }
  },
  "borderRadius": {
    "sm":   { "$value": "8px",   "$type": "dimension" },
    "md":   { "$value": "12px",  "$type": "dimension" },
    "lg":   { "$value": "20px",  "$type": "dimension", "$description": "Cards (desktop: 24px)" },
    "full": { "$value": "9999px","$type": "dimension", "$description": "Pills / badges" }
  },
  "darkMode": {
    "colors": {
      "text": {
        "caption":  { "$value": "#d8d8d8", "$type": "color", "$description": "colors/text/caption — dark mode" }
      },
      "surface": {
        "white":     { "$value": "#ffffff", "$type": "color" },
        "fakeWhite": { "$value": "#1d1d1d", "$type": "color", "$description": "colors/surface/fake white — dark card bg" }
      },
      "border": {
        "medium": { "$value": "#939292", "$type": "color", "$description": "colors/border/medium" }
      },
      "neutral": {
        "lowest": { "$value": "#f7f7f7", "$type": "color" }
      }
    },
    "overlay": {
      "color":  { "$value": "#202020cc", "$type": "color", "$description": "overlay/color/color — dark mode" },
      "strong": { "$value": "#20202099", "$type": "color", "$description": "transparency/overlay/strong" }
    }
  },
  "components": {
    "actionSheet": {
      "icon": {
        "default":     { "$value": "#939292", "$type": "color", "$description": "action-sheet/icon/default" },
        "disabled":    { "$value": "#4d4d4d", "$type": "color", "$description": "action-sheet/icon/disabled" },
        "destructive": { "$value": "#f4a8a4", "$type": "color", "$description": "action-sheet/icon/destructive" }
      },
      "text": {
        "default":     { "$value": "#f7f7f7", "$type": "color", "$description": "action-sheet/text/default" },
        "disabled":    { "$value": "#4d4d4d", "$type": "color", "$description": "action-sheet/text/disabled" },
        "destructive": { "$value": "#f4a8a4", "$type": "color", "$description": "action-sheet/text/destructive" }
      }
    },
    "bottomSheet": {
      "background": { "$value": "#000000", "$type": "color", "$description": "bottom-sheet/background/default" },
      "dragHandle": { "$value": "#939292", "$type": "color", "$description": "bottom-sheet/drag-handle/default" }
    }
  },
  "effects": {
    "blur": {
      "500": { "$value": "16px", "$type": "dimension", "$description": "blur/500 — background blur" }
    }
  },
  "shadow": {
    "card": {
      "$value": {
        "color": "rgba(0,0,0,0.06)",
        "offsetX": "0",
        "offsetY": "4px",
        "blur": "12px",
        "spread": "0"
      },
      "$type": "shadow"
    },
    "modal": {
      "$value": {
        "color": "rgba(0,0,0,0.15)",
        "offsetX": "0",
        "offsetY": "12px",
        "blur": "32px",
        "spread": "0"
      },
      "$type": "shadow"
    }
  }
}
