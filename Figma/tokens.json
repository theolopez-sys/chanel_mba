{
  "$schema": "https://tr.designtokens.org/format/",
  "description": "Internal European Design System — Design Tokens (W3C DTCG format)",
  "colors": {
    "black": {
      "$value": "#000000",
      "$type": "color",
      "$description": "var(--colors/black)"
    },
    "white": {
      "$value": "#FFFFFF",
      "$type": "color",
      "$description": "var(--colors/white)"
    },
    "accent": {
      "$value": "#B8964E",
      "$type": "color",
      "$description": "Gold accent — use sparingly"
    },
    "neutral": {
      "lower": {
        "$value": "#EDEDED",
        "$type": "color",
        "$description": "var(--colors/neutral/lower) — page background"
      },
      "mid": {
        "$value": "#D4D4D4",
        "$type": "color"
      },
      "high": {
        "$value": "#A0A0A0",
        "$type": "color"
      }
    },
    "surface": {
      "white": {
        "$value": "#FFFFFF",
        "$type": "color",
        "$description": "var(--colors/surface/white) — card background"
      }
    },
    "text": {
      "heading": {
        "$value": "#000000",
        "$type": "color",
        "$description": "var(--colors/text/heading)"
      },
      "body": {
        "$value": "#333333",
        "$type": "color",
        "$description": "var(--colors/text/body)"
      },
      "muted": {
        "$value": "#888888",
        "$type": "color"
      },
      "inverted": {
        "$value": "#FFFFFF",
        "$type": "color"
      }
    },
    "status": {
      "success": { "$value": "#2D6A4F", "$type": "color" },
      "warning": { "$value": "#E9C46A", "$type": "color" },
      "error":   { "$value": "#C1121F", "$type": "color" },
      "info":    { "$value": "#023E8A", "$type": "color" }
    }
  },
  "typography": {
    "fontFamily": {
      "title": {
        "$value": "ABChanel Corpo 2022",
        "$type": "fontFamily",
        "$description": "var(--font/family/title) — Semi Bold, uppercase headings"
      },
      "text": {
        "$value": "Helvetica",
        "$type": "fontFamily",
        "$description": "var(--font/family/text) — body copy"
      }
    },
    "fontWeight": {
      "regular":  { "$value": 400, "$type": "fontWeight" },
      "semiBold": { "$value": 600, "$type": "fontWeight", "$description": "var(--font/weight/semi-bold)" },
      "bold":     { "$value": 700, "$type": "fontWeight" }
    },
    "fontSize": {
      "micro": { "$value": "10px", "$type": "dimension" },
      "xs":    { "$value": "11px", "$type": "dimension" },
      "sm":    { "$value": "13px", "$type": "dimension" },
      "base":  { "$value": "15px", "$type": "dimension" },
      "lg":    { "$value": "20px", "$type": "dimension", "$description": "var(--font/size/lg) — desktop" },
      "xl":    { "$value": "22px", "$type": "dimension" },
      "2xl":   { "$value": "28px", "$type": "dimension" },
      "3xl":   { "$value": "40px", "$type": "dimension", "$description": "var(--font/size/3xl) — desktop" },
      "hero":  { "$value": "64px", "$type": "dimension", "$description": "Hero / page title — desktop" }
    },
    "lineHeight": {
      "tight":  { "$value": 1.1,  "$type": "number" },
      "normal": { "$value": 1.4,  "$type": "number", "$description": "Default body line-height" },
      "loose":  { "$value": 1.6,  "$type": "number" }
    },
    "letterSpacing": {
      "label":   { "$value": "0.15em", "$type": "dimension", "$description": "Uppercase labels" },
      "heading": { "$value": "0.02em", "$type": "dimension" },
      "tight":   { "$value": "0",      "$type": "dimension" }
    }
  },
  "spacing": {
    "1":  { "$value": "4px",  "$type": "dimension" },
    "2":  { "$value": "8px",  "$type": "dimension" },
    "3":  { "$value": "12px", "$type": "dimension" },
    "4":  { "$value": "16px", "$type": "dimension" },
    "5":  { "$value": "20px", "$type": "dimension" },
    "6":  { "$value": "24px", "$type": "dimension" },
    "8":  { "$value": "32px", "$type": "dimension" },
    "10": { "$value": "40px", "$type": "dimension" },
    "12": { "$value": "48px", "$type": "dimension" },
    "page": {
      "desktop": { "$value": "160px", "$type": "dimension", "$description": "Desktop horizontal padding" },
      "mobile":  { "$value": "20px",  "$type": "dimension", "$description": "Mobile horizontal padding" }
    }
  },
  "borderRadius": {
    "sm":   { "$value": "8px",   "$type": "dimension" },
    "md":   { "$value": "12px",  "$type": "dimension" },
    "lg":   { "$value": "20px",  "$type": "dimension", "$description": "Cards (desktop: 24px)" },
    "full": { "$value": "9999px","$type": "dimension", "$description": "Pills / badges" }
  },
  "shadow": {
    "card": {
      "$value": {
        "color": "rgba(0,0,0,0.06)",
        "offsetX": "0",
        "offsetY": "4px",
        "blur": "12px",
        "spread": "0"
      },
      "$type": "shadow"
    },
    "modal": {
      "$value": {
        "color": "rgba(0,0,0,0.15)",
        "offsetX": "0",
        "offsetY": "12px",
        "blur": "32px",
        "spread": "0"
      },
      "$type": "shadow"
    }
  }
}
